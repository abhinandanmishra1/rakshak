# Rakshak Backend Environment Configuration
# Replace the placeholder below with your real Gemini API Key from Google AI Studio.

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# The model to use for analysis (e.g. gemini-1.5-flash or gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-1.5-flash

# Local server binding port
PORT=5001
