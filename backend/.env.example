# Rakshak Backend Environment Configuration Example
# Copy this file to .env and configure your real credentials. Do NOT commit your real .env file.

# Google Gemini API Key from Google AI Studio
# Obtain a key at: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# The model to use for analysis (e.g. gemini-1.5-flash or gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-1.5-flash

# Local server binding port
PORT=5001
